# ========================= Base Config =========================
# Default: SQLite (no extra database needed, zero config for local dev)
# For PostgreSQL, uncomment and edit:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/xiaoyunque
DATABASE_URL=sqlite:///./xiaoyunque.db
DEBUG=true
API_V1_PREFIX=/api/v1
PROJECT_NAME=XingHe

# JWT secret: change to a random string in production
SECRET_KEY=your-secret-key-change-in-production

# Public URL for local dev
PUBLIC_BASE_URL=http://localhost:8000

# ========================= Tencent COS =========================
# Leave empty to use local disk storage (/static path)
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=

# ========================= DashScope (Aliyun) =========================
DASHSCOPE_API_BASE_URL=
DASHSCOPE_API_KEY=

# ========================= Volcengine Ark =========================
VOLCENGINE_ARK_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_ARK_API_KEY=
VOLCENGINE_ARK_MODEL_ID_STANDARD=
VOLCENGINE_ARK_MODEL_ID_FAST=

# ========================= 91API =========================
# Leave empty for mock demo data
API91_BASE_URL=
API91_API_KEY=

# ========================= Model Config =========================
LLM_MODEL_NAME=deepseek-v4-flash
LLM_PROVIDER=api91
IMAGE_MODEL_GPT_IMAGE_2=gpt-image-2
IMAGE_MODEL_GEMINI_FLASH_IMAGE=gemini-3.1-flash-lite-image

# ========================= SMS (optional) =========================
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

# ========================= Turnstile (optional) =========================
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ========================= Admin Account =========================
# Auto-created on first startup if no admin exists
ADMIN_EMAIL=admin@xinghe.com
ADMIN_PASSWORD=admin123456
