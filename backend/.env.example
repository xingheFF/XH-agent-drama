# ========================= 基础服务配置 =========================
DATABASE_URL=sqlite:///./xiaoyunque.db
DEBUG=true
API_V1_PREFIX=/api/v1
PROJECT_NAME=小云雀后端

# 服务公网地址（用于把本地 /uploads 相对地址转成可访问的绝对 URL）
PUBLIC_BASE_URL=http://localhost:8000

# 切换到 PostgreSQL 时使用:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/xiaoyunque

# ========================= 腾讯云 COS 配置 =========================
# COS 密钥，前往 https://console.cloud.tencent.com/cam/capi 获取
TENCENT_COS_SECRET_ID=your-secret-id-here
TENCENT_COS_SECRET_KEY=
# 存储桶名称，例如：xiaoyunque-1234567890
TENCENT_COS_BUCKET=your-bucket-name
# 存储桶地域，例如：ap-beijing、ap-shanghai、ap-guangzhou
TENCENT_COS_REGION=ap-shanghai

# ========================= 阿里云百炼（DashScope）配置 =========================
# 用于万相 2.7 视频生成（wan2.7-video）等模型
# 获取地址：https://help.aliyun.com/zh/dashscope/
DASHSCOPE_API_BASE_URL=https://dashscope.aliyuncs.com/api/v1
DASHSCOPE_API_KEY=

# ========================= 火山引擎 Ark 配置 =========================
# 用于 LLM 对话、豆包 Seedance 2.0 视频生成
# 获取地址：https://console.volcengine.com/ark/
VOLCENGINE_ARK_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_ARK_API_KEY=
# Seedance 2.0 模型/推理端点 ID，一般无需修改
VOLCENGINE_ARK_MODEL_ID_STANDARD=
VOLCENGINE_ARK_MODEL_ID_FAST=

# ========================= 91API 配置 =========================
# 用于 gpt-image-2、gemini-3.1-flash-image-preview 等图片模型
# 在 .env 中填入真实 key；留空则走 mock 演示数据
API91_BASE_URL=
API91_API_KEY=

# ========================= ToonFlow 配置 =========================
# ToonFlow 官方中转平台 - 可灵/Seedance 视频模型
# 用于 Kling-V3-Omni、Seedance 2.0、Seedance 2.0 fast 等视频模型
# 获取地址：https://api.toonflow.net/
TOONFLOW_API_BASE_URL=https://api.toonflow.net/v1
TOONFLOW_API_KEY=

# ========================= 默认模型配置 =========================
# 默认 LLM 模型（对话 / 剧本生成）
LLM_MODEL_NAME=gpt-5.6-terra
# LLM 提供商：ark（火山方舟）或 api（API，默认，因默认模型为 API 模型）
LLM_PROVIDER=api
# 默认图片模型（环境变量值即模型 ID）
IMAGE_MODEL_GPT_IMAGE_2=gpt-image-2
IMAGE_MODEL_GEMINI_FLASH_IMAGE=gemini-3.1-flash-lite-image

# ========================= 可选扩展（当前未使用） =========================
# 使用 PostgreSQL 时取消注释:
# psycopg2-binary==2.9.9
# 使用 Redis 时取消注释:
# redis==5.1.1
# celery==5.4.0
